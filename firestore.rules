rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins: dürfen alle Benutzer-Profile lesen/schreiben (Admin-Console).
    // Dieselbe(n) Adresse(n) wie ADMIN_EMAILS in firebase-config.js!
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['heebalessio@gmail.com'];
    }

    match /users/{uid} {
      // Jeder eingeloggte Benutzer: nur sein eigenes Profil.
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Admins: alle Profile.
      allow read, write: if isAdmin();
    }
  }
}
