rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admins: per E-Mail bestimmt. Dieselbe(n) Adresse(n) wie ADMIN_EMAILS in firebase-config.js!
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['heebalessio@gmail.com'];
    }

    match /users/{uid} {
      // Lesen: eigenes Profil oder Admin.
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());

      // Anlegen/Löschen NUR Admin → niemand kann sich selbst registrieren.
      allow create, delete: if isAdmin();

      // Ändern: Admin alles; der Eigentümer nur, ohne role/disabled zu verändern
      // (keine Selbst-Hochstufung zum Admin, kein Aufheben einer Sperre).
      allow update: if isAdmin()
        || ( request.auth != null && request.auth.uid == uid
             && request.resource.data.role == resource.data.role
             && request.resource.data.disabled == resource.data.disabled );
    }

    // Alles andere ist standardmäßig gesperrt (kein Zugriff auf andere Collections).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
